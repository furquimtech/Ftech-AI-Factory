# ──────────────────────────────────────────────────────────
# FTech AI Factory – environment variables
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ftechai:ftechai@localhost:5432/ftechai_factory

# ── LLM (one provider name per agent role) ─────────────────
# Available: llama
LLM_DEV=llama
LLM_QA=llama
LLM_DOC=llama
LLM_KNOWLEDGE=llama

# LLaMA / Ollama local server
LLAMA_BASE_URL=http://localhost:11434
LLAMA_MODEL=llama3

# ── Azure DevOps ───────────────────────────────────────────
AZURE_DEVOPS_ORG=your-org
AZURE_DEVOPS_PROJECT=your-project
AZURE_DEVOPS_PAT=your-pat-token

# ── GitHub ─────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=owner/repo

# ── Orchestrator ───────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
MAX_PARALLEL_AGENTS=4
SCHEDULER_INTERVAL=30    # seconds between queue polls

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Resilience ─────────────────────────────────────────────
MAX_RETRIES=3
